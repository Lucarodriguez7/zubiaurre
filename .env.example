# ─────────────────────────────────────────────
#  Variables de entorno para el proxy Node.js
#  Copiá este archivo como .env y completá tu key
# ─────────────────────────────────────────────

# API Key de Tokko Broker (la encontrás en tu cuenta de Tokko)
TOKKO_API_KEY=pegá_tu_api_key_aqui

# Puerto del proxy (opcional, por defecto 3001)
PORT=3001
